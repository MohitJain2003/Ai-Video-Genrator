# === Application ===
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# === Database ===
DATABASE_URL=sqlite:///./storage/db/reelgen.db

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === AI / LLM Providers (at least one required) ===
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# === Voice Providers (at least one required) ===
ELEVENLABS_API_KEY=xi-...
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
OPENAI_TTS_VOICE=onyx
CARTESIA_API_KEY=...
CARTESIA_VOICE_ID=...

# === Video Generation Providers (at least one required) ===
GOOGLE_API_KEY=...
RUNWAYML_API_SECRET=...
KLING_API_KEY=...

# === Stock Footage ===
PEXELS_API_KEY=...

# === Storage ===
STORAGE_PATH=./storage

DEFAULT_LLM_PROVIDER=openai
DEFAULT_VOICE_PROVIDER=openai
DEFAULT_VIDEO_PROVIDER=veo
DEFAULT_VOICE_LANGUAGE=hinglish

# === Quality & Retries ===
# Threshold (0-100) below which the generation pipeline will retry. Set to 0 to disable quality retries completely.
QUALITY_THRESHOLD=75
MAX_RETRIES=1
